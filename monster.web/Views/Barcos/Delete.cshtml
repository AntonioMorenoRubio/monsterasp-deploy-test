@model monster.web.Domain.Entities.Barco

@{
    ViewData["Title"] = $"Borrar: {@Model.Nombre}";
}

<h1>Borrar</h1>

<h3>¿Estás seguro de querer borrar este barco?</h3>
<div>
    <h4>@Model.Nombre</h4>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Nombre)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Nombre)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Nacion)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Nacion)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Nivel)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Nivel)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Tipo)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Tipo)
        </dd>
    </dl>
    
    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <input type="submit" value="Borrar definitivamente" class="btn btn-danger" /> |
        <a asp-action="Index">Volver a Lista</a>
    </form>
</div>
